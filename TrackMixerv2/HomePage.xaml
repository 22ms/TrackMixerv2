<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TrackMixerv2.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TrackMixerv2"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource LayerFillColorDefault}">

    <Grid VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" BorderThickness="0, 0, 0, 1" BorderBrush="{ThemeResource DividerStrokeColorDefault}" Orientation="Horizontal">
            <TextBlock Margin="15, 10, 10, 10" HorizontalAlignment="Stretch" Text="Hello, User! Please set your root folder to continue🥺" Style="{ThemeResource SubtitleTextBlockStyle}"/>
        </StackPanel>
        <Grid Grid.Row="1" Background="{ThemeResource SolidBackgroundFillColorBase}">
            <!--<Button VerticalAlignment="Center" HorizontalAlignment="Center" Width="200" Height="50">
                <TextBlock Text="Set root folder" Style="{ThemeResource SubtitleTextBlockStyle}"/>
            </Button>-->
            <local:VideoExplorer/>
        </Grid>
    </Grid>
</Page>

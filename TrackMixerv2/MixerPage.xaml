<?xml version="1.0" encoding="utf-8"?>

<Page

    x:Class="TrackMixerv2.MixerPage"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:local="using:TrackMixerv2"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    mc:Ignorable="d"

    HighContrastAdjustment="Auto">



    <Grid x:Name="PageRootGrid" x:FieldModifier="public" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="{ThemeResource LayerFillColorDefault}" AllowDrop="True">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>



        <MenuBar x:Name="MainMenuBar" Grid.Row="0">

            <MenuBarItem x:Name="FileMenuBarItem" Title="File">

                <MenuFlyoutItem x:FieldModifier="public" x:Name="OpenFileFlyout" Text="Open" Tag="openFile" />

                <MenuFlyoutItem x:FieldModifier="public" x:Name="ManageRootFoldersFlyout" Text="Root folders" Tag="manageRootFolders"/>

                <MenuFlyoutItem x:FieldModifier="public" x:Name="ExportFlyout" Text="Export current file" Tag="exportFile"/>

            </MenuBarItem>

            <MenuBarItem Title="Edit">

                <MenuFlyoutItem Text="Preferences" Click="Preferences_Click"/>

            </MenuBarItem>

            <MenuBarItem Title="Help">

                <MenuFlyoutItem Text="Discord" Click="OpenLink_Click" Tag="https://discord.com/invite/dWUmubXAXv"/>

                <MenuFlyoutItem Text="Reddit" Click="OpenLink_Click" Tag="https://www.reddit.com/r/trackmixer"/>

                <MenuFlyoutItem Text="Ko-fi" Click="OpenLink_Click" Tag="https://ko-fi.com/doppelzwei"/>

            </MenuBarItem>

        </MenuBar>



        <ContentDialog x:Name="PreferencesDialog"

               Title="Preferences"

               PrimaryButtonText="OK"

               CloseButtonText="Cancel"

               DefaultButton="Primary">

            <ScrollViewer x:Name="PreferencesScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          ZoomMode="Disabled"
                          Padding="0,0,12,0">
                <StackPanel x:Name="PreferencesContentPanel" Spacing="12" MinWidth="360">

                <CheckBox x:Name="DragAndDropCheckBox" Content="Open drag-and-drop on new tab"/>

                <CheckBox x:Name="DoubleClickCheckBox" Content="Open double-click on new tab"/>

                <TextBlock Text="Skip amount (seconds)" />
                <NumberBox x:Name="SkipSecondsNumberBox"
                           Minimum="1"
                           Maximum="300"
                           Value="5"
                           SmallChange="1"
                           LargeChange="5"
                           HorizontalAlignment="Stretch" />

                <TextBlock Text="Slider mouse wheel speed" />
                <NumberBox x:Name="SliderWheelSpeedNumberBox"
                           Minimum="1"
                           Maximum="20"
                           Value="2"
                           SmallChange="1"
                           LargeChange="1"
                           HorizontalAlignment="Stretch" />
                <TextBlock Text="Multiplies each slider's own step (volume, rating, progress, and transport)."
                           TextWrapping="WrapWholeWords"
                           Opacity="0.8"
                           FontSize="12" />

                <TextBlock Text="Speed boost rate (hold keybind)" />
                <ComboBox x:Name="SpeedBoostRateComboBox"
                          HorizontalAlignment="Stretch" />

                <TextBlock Text="Slow motion rate (hold keybind)" />
                <ComboBox x:Name="SpeedSlowRateComboBox"
                          HorizontalAlignment="Stretch" />
                <TextBlock Text="Same speeds as the transport bar. Applied while the shortcut is held."
                           TextWrapping="WrapWholeWords"
                           Opacity="0.8"
                           FontSize="12" />

                <CheckBox x:Name="ShowAdvancedSettingsCheckBox"
                          Content="Show advanced settings"
                          Checked="ShowAdvancedSettingsCheckBox_Changed"
                          Unchecked="ShowAdvancedSettingsCheckBox_Changed" />

                <StackPanel x:Name="AdvancedPreferencesPanel"
                            Spacing="8"
                            Visibility="Collapsed">
                    <TextBlock Text="Transport bar speeds"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Choose which playback speeds appear in the transport menu and hold-keybind lists. 1× always stays available."
                               TextWrapping="WrapWholeWords"
                               Opacity="0.8"
                               FontSize="12" />
                    <StackPanel x:Name="TransportRatesPanel" Spacing="6" />
                    <TextBlock Text="Add a speed"
                               Opacity="0.8"
                               FontSize="12" />
                    <AutoSuggestBox x:Name="TransportRateAddBox"
                                    PlaceholderText="e.g. 1.5 or 1,5"
                                    QueryIcon="Add"
                                    QuerySubmitted="TransportRateAddBox_QuerySubmitted"
                                    HorizontalAlignment="Stretch"
                                    ToolTipService.ToolTip="Add speed" />
                    <Button Content="Reset transport speeds to default"
                            Click="ResetTransportRates_Click"
                            HorizontalAlignment="Left" />
                </StackPanel>

                </StackPanel>
            </ScrollViewer>

        </ContentDialog>

        <ContentDialog x:Name="RootFoldersDialog"
                       Title="Root folders"
                       PrimaryButtonText="Close"
                       DefaultButton="Primary">
            <StackPanel Spacing="12" MinWidth="420">
                <TextBlock Text="Clips under these folders are used for automatic playlist sorting."
                           TextWrapping="WrapWholeWords"
                           Opacity="0.8" />
                <TextBlock x:Name="RootFolderEnvVarInfoText"
                           TextWrapping="WrapWholeWords"
                           Opacity="0.8"
                           FontSize="12" />
                <Grid MinHeight="48" MaxHeight="240">
                    <ListView x:Name="RootFolderList"
                              SelectionMode="None"
                              IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Grid ColumnSpacing="12" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               ToolTipService.ToolTip="{x:Bind}" />
                                    <Button Grid.Column="1"
                                            Content="Remove"
                                            Tag="{x:Bind}"
                                            Click="RemoveRootFolder_Click" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="RootFolderEmptyText"
                               Text="No root folders yet."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.55" />
                </Grid>
                <Button x:Name="AddRootFolderButton"
                        Content="Add folder..."
                        HorizontalAlignment="Stretch"
                        Click="AddRootFolderButton_Click" />
                <CheckBox x:Name="SuppressRootFolderPromptCheckBox"
                          Content="Don't ask to add root folders automatically"
                          Checked="SuppressRootFolderPromptCheckBox_Changed"
                          Unchecked="SuppressRootFolderPromptCheckBox_Changed" />
            </StackPanel>
        </ContentDialog>



        <Border BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefault}" Grid.Row="1" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">

            <TextBlock Margin="0,8,0,8" x:Name="VideoTitle" AutomationProperties.AutomationId="VideoTitle" Text="No clip selected" Style="{ThemeResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" TextAlignment="Center"/>

        </Border>



        <Border Grid.Row="2">

            <local:MixedMediaPlayer x:FieldModifier="public" x:Name="MixedMediaPlayer"/>

        </Border>



        <Border Grid.Row="3"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                Padding="14,12">
            <Grid ColumnSpacing="14" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        VerticalAlignment="Stretch"
                        MinHeight="96"
                        Padding="10,10"
                        BorderBrush="{ThemeResource DividerStrokeColorDefault}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Background="{ThemeResource LayerFillColorAltBrush}">
                    <Grid ColumnSpacing="12" VerticalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid x:Name="VolumeControlGrid"
                              Grid.Column="0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                        <Border Grid.Column="1"
                                Width="1"
                                Margin="0,4"
                                VerticalAlignment="Stretch"
                                Background="{ThemeResource DividerStrokeColorDefault}"/>
                        <Grid Grid.Column="2"
                              RowSpacing="8"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid x:Name="ExportDeleteRow" Grid.Row="0" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="ExportButton"
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        AutomationProperties.AutomationId="ExportButton"
                                        Click="ExportButton_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Padding="12,8"
                                        ToolTipService.ToolTip="Export current clip with track mix">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE898;" FontSize="14"/>
                                        <TextBlock Text="Export" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="DeleteVideoButton"
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        AutomationProperties.AutomationId="DeleteVideoButton"
                                        Style="{StaticResource DestructiveButtonStyle}"
                                        ToolTipService.ToolTip="Delete video"
                                        Padding="12,8">
                                    <Button.Flyout>
                                        <Flyout x:Name="DeleteConfirmationFlyout" Opened="DeleteConfirmationFlyout_Opened" Closed="DeleteConfirmationFlyout_Closed">
                                            <StackPanel>
                                                <TextBlock Text="Are you sure you want to delete this video? (Recycle bin)" Margin="5" />
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                                                    <Button Content="Yes" Click="DeleteVideoConfirmation_Click" Style="{StaticResource DestructiveButtonStyle}" Margin="5,0" AutomationProperties.AutomationId="DeleteVideoConfirmButton" />
                                                    <Button Content="No" Click="CancelDelete_Click" Margin="5,0" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                        <TextBlock Text="Delete" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <Grid x:Name="RatingPlaylistRow" Grid.Row="1" ColumnSpacing="10" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid x:Name="RatingControlsGrid" Grid.Column="0" ColumnSpacing="8" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE8E0;" FontSize="12" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1"
                                            x:Name="RatingSlider"
                                            Margin="4,0"
                                            HorizontalAlignment="Stretch"
                                            AutomationProperties.AutomationId="RatingSlider"
                                            AutomationProperties.Name="Rating"
                                            TickFrequency="10"
                                            TickPlacement="None"
                                            SnapsTo="StepValues"
                                            VerticalAlignment="Center"
                                            Minimum="0"
                                            Maximum="100"/>
                                    <FontIcon Grid.Column="2" Glyph="&#xE8E1;" FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel x:Name="PlaylistControlsStack"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="6"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                    <Border Width="1"
                                            Height="24"
                                            Background="{ThemeResource DividerStrokeColorDefault}"
                                            VerticalAlignment="Center"
                                            Margin="0,0,4,0"/>
                                    <NumberBox x:Name="PlaylistFilterTimeValue"
                                               CornerRadius="4,0,0,4"
                                               Visibility="Collapsed"
                                               Value="30"
                                               SpinButtonPlacementMode="Compact"
                                               SmallChange="1"
                                               LargeChange="10"
                                               FontSize="12"/>
                                    <ComboBox x:Name="PlaylistFilterTimeUnit"
                                              SelectedIndex="0"
                                              CornerRadius="0,4,4,0"
                                              Visibility="Collapsed"
                                              FontSize="12"
                                              MinWidth="68">
                                        <x:String>Days</x:String>
                                        <x:String>Weeks</x:String>
                                        <x:String>Months</x:String>
                                        <x:String>Years</x:String>
                                    </ComboBox>
                                    <DropDownButton x:Name="PlaylistFilterDropdown"
                                                      ToolTipService.ToolTip="Playlist sort mode"
                                                      CornerRadius="4,0,0,4"
                                                      Padding="8,6">
                                        <DropDownButton.Content>
                                            <FontIcon x:Name="PlaylistFilterSelectionIcon" Glyph="&#xE81C;" FontSize="13"/>
                                        </DropDownButton.Content>
                                        <DropDownButton.Flyout>
                                            <MenuFlyout Placement="Top"
                                                        MenuFlyoutPresenterStyle="{StaticResource CompactMenuFlyoutPresenterStyle}">
                                                <RadioMenuFlyoutItem x:Name="PlaylistFilterChrono"
                                                                     Style="{StaticResource CompactSelectionFlyoutRadioItemStyle}"
                                                                     Text="Chrono"
                                                                     GroupName="PlaylistFilter"
                                                                     Tag="chrono"
                                                                     IsChecked="True" />
                                                <RadioMenuFlyoutItem x:Name="PlaylistFilterRating"
                                                                     Style="{StaticResource CompactSelectionFlyoutRadioItemStyle}"
                                                                     Text="Rating"
                                                                     GroupName="PlaylistFilter"
                                                                     Tag="rating" />
                                            </MenuFlyout>
                                        </DropDownButton.Flyout>
                                    </DropDownButton>
                                    <ToggleButton x:Name="PlaylistSubfolderToggle"
                                                  ToolTipService.ToolTip="Current subfolder only"
                                                  CornerRadius="0,4,4,0"
                                                  Padding="8,6">
                                        <FontIcon Glyph="&#xE8F7;" FontSize="13"/>
                                    </ToggleButton>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        VerticalAlignment="Stretch"
                        Padding="0"
                        BorderBrush="{ThemeResource DividerStrokeColorDefault}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Background="{ThemeResource LayerFillColorAltBrush}">
                    <Grid VerticalAlignment="Stretch">
                        <Grid x:Name="KeybindListGrid" VerticalAlignment="Stretch"/>
                        <TextBox x:Name="KeybindRecordingCapture"
                                 Width="1"
                                 Height="1"
                                 Opacity="0"
                                 IsReadOnly="True"
                                 IsTabStop="False"
                                 IsHitTestVisible="False"
                                 BorderThickness="0"
                                 Padding="0"
                                 AutomationProperties.AccessibilityView="Raw"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>

</Page>


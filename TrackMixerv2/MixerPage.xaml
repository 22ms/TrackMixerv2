<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TrackMixerv2.MixerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TrackMixerv2"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    HighContrastAdjustment="Auto"
    >

    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="{ThemeResource LayerFillColorDefault}" AllowDrop="True">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Left" Invoked="Left_Invoked"/>
            <KeyboardAccelerator Key="Right" Invoked="Right_Invoked"/>
            <KeyboardAccelerator Key="Space" Invoked="Space_Invoked"/>
        </Grid.KeyboardAccelerators>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!--<Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>-->
        <MenuBar Grid.Row="0" Grid.Column="0">
            <MenuBarItem Title="File">
                <MenuFlyoutItem x:FieldModifier="public" x:Name="OpenFileFlyout" Text="Open..." Tag="openFile" />
                <MenuFlyoutItem x:FieldModifier="public" x:Name="AddRootFlyout" Text="Add root folder" Tag="addRootFolder"/>
                <MenuFlyoutItem x:FieldModifier="public" x:Name="ExportFlyout" Text="Export current file..." Tag="exportFile"/>
            </MenuBarItem>
            <MenuBarItem Title="Edit">
                <MenuFlyoutItem Text="Preferences" Click="Preferences_Click"/>
            </MenuBarItem>
        </MenuBar>
        <ContentDialog x:Name="PreferencesDialog"
               Title="Preferences"
               PrimaryButtonText="OK"
               CloseButtonText="Cancel"
               DefaultButton="Primary">
            <StackPanel>
                <CheckBox x:Name="DragAndDropCheckBox" Content="Open drag-and-drop on new tab"/>
                <CheckBox x:Name="DoubleClickCheckBox" Content="Open double-click on new tab"/>
            </StackPanel>
        </ContentDialog>
        <Border BorderThickness="0, 1, 0, 0" BorderBrush="{ThemeResource DividerStrokeColorDefault}" Grid.Column="1" Grid.Row="1" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <TextBlock Margin="0, 10, 0, 10" x:Name="VideoTitle" Text="No clip selected" Style="{ThemeResource TitleTextBlockStyle}" HorizontalAlignment="Center" TextAlignment="Center"/>
        </Border>
        <Border Grid.Column="1" Grid.Row="2">
            <local:MixedMediaPlayer x:Name="MixedMediaPlayer"/>
        </Border>
        <Grid BorderThickness="0, 1, 0, 0" BorderBrush="{ThemeResource DividerStrokeColorDefault}" Grid.Column="1" Grid.Row="3" Padding="20, 20, 20, 20" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Column="0" x:Name="VolumeControlGrid" HorizontalAlignment="Center" BorderBrush="{ThemeResource DividerStrokeColorDefault}" BorderThickness="1" CornerRadius="5" Background="{ThemeResource LayerFillColorAltBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
            </Grid>
            <Grid Grid.Column="1" Padding="20, 0, 20, 10" BorderBrush="{ThemeResource DividerStrokeColorDefault}" BorderThickness="1" CornerRadius="5" Background="{ThemeResource LayerFillColorAltBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnSpacing>10</Grid.ColumnSpacing>
                <SymbolIcon Grid.Row="0" Grid.Column="0" Symbol="Dislike" />
                <SymbolIcon Grid.Row="0" Grid.Column="2" Symbol="Like" />
                <Slider x:Name="RatingSlider" Grid.Row="0" Grid.Column="1" AutomationProperties.Name="Slider with ticks" TickFrequency="10" TickPlacement="Outside" SnapsTo="StepValues" VerticalAlignment="Center" Minimum="0" Maximum="100"/>
                <StackPanel Padding="7, 2, 7, 7" Orientation="Vertical" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="{ThemeResource DividerStrokeColorDefault}" BorderThickness="1" CornerRadius="5" Background="{ThemeResource LayerFillColorAltBrush}">
                    <TextBlock Text="Playlist filtering" Margin="0, 0, 0, 10" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal">
                        <NumberBox x:Name="PlaylistFilterTimeValue" CornerRadius="5, 0, 0, 5" Margin="10, 0, 0, 0" Visibility="Collapsed"
                        Value="30"
                        SpinButtonPlacementMode="Compact"
                        SmallChange="1"
                        LargeChange="10" Width="45"/>
                        <ComboBox x:Name="PlaylistFilterTimeUnit" SelectedIndex="0" CornerRadius="0, 5, 5, 0" Margin="0, 0, 5, 0" Visibility="Collapsed">
                            <x:String>Days</x:String>
                            <x:String>Weeks</x:String>
                            <x:String>Months</x:String>
                            <x:String>Years</x:String>
                        </ComboBox>
                        <DropDownButton ToolTipService.ToolTip="Set playlist sorting mode" CornerRadius="5, 0, 0, 5">
                            <DropDownButton.Content>
                                <FontIcon x:Name="PlaylistFilterSelectionIcon" Glyph="&#xE81C;" Margin="0, 0, 10, 0"/>
                            </DropDownButton.Content>
                            <DropDownButton.Flyout>
                                <MenuFlyout Placement="Top">
                                    <MenuFlyoutItem x:Name="PlaylistFilterChrono" Text="Chrono" Tag="chrono">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE81C;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem x:Name="PlaylistFilterRating" Text="Rating" Tag="rating">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE728;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <ToggleButton x:Name="PlaylistSubfolderToggle" ToolTipService.ToolTip="Playlist in current subfolder only (toggle)" CornerRadius="0, 5, 5, 0">
                            <FontIcon Glyph="&#xE8F7;"/>
                        </ToggleButton>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Row="1" Grid.Column="2" ToolTipService.ToolTip="Delete video" Margin="10, 0, 0, 0" Background="Red" CornerRadius="5">
                    <Button.Flyout>
                        <Flyout x:Name="DeleteConfirmationFlyout" Opened="DeleteConfirmationFlyout_Opened" Closed="DeleteConfirmationFlyout_Closed">
                            <StackPanel>
                                <TextBlock Text="Are you sure you want to delete this video? (Recycle bin)" Margin="5" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                                    <Button Content="Yes" Click="DeleteVideoConfirmation_Click" Background="Red" Foreground="White" Margin="5, 0" />
                                    <Button Content="No" Click="CancelDelete_Click" Margin="5, 0" />
                                </StackPanel>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                    <FontIcon Glyph="&#xE74D;" />
                </Button>

            </Grid>
        </Grid>
        <!--<Border  Grid.Row="4" Grid.Column="1" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <TextBlock Text="😊" HorizontalAlignment="Center" Padding="10, 10, 10, 10"/>
        </Border>-->
    </Grid>
</Page>

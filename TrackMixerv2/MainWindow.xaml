<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TrackMixerv2.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TrackMixerv2"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    >

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" x:FieldModifier="public">
        <TabView x:Name="TabView" Loaded="TabView_Loaded" x:FieldModifier="public" AutomationProperties.AutomationId="MainTabView">

        <TabView.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceDictionary Source="Styles.xaml"/>
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </TabView.Resources>

        <TabView.TabStripHeader>
            <Grid x:Name="ShellTitlebarInset"/>
        </TabView.TabStripHeader>
        <TabView.TabStripFooter>
            <Grid Background="Transparent" x:Name="CustomDragRegion" MinWidth="188"/>
        </TabView.TabStripFooter>

        </TabView>

        <Grid x:Name="PlayerFullScreenOverlay"
              Visibility="Collapsed"
              Background="Black">
            <Grid x:Name="PlayerFullScreenHost" />
        </Grid>
    </Grid>
</Window>

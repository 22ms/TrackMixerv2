<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TrackMixerv2.MixedMediaPlayer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TrackMixerv2"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    >

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <MediaPlayerElement x:Name="MainMediaPlayer" x:FieldModifier="public" AllowDrop="True" PointerPressed="MainMediaPlayer_PointerPressed" PointerReleased="MainMediaPlayer_PointerReleased"
        AutoPlay="True"
        AreTransportControlsEnabled="True"
        Stretch="Uniform" CanDrag="True">
            <MediaPlayerElement.TransportControls>
                <local:MixedMediaPlayerControl x:Name="customMixedMediaPlayerControl" x:FieldModifier="public"
                                               IsNextTrackButtonVisible="True"
                                               IsPreviousTrackButtonVisible="True"
                                               IsPlaybackRateEnabled="False"
                                               IsPlaybackRateButtonVisible="False"
                                               IsCompact="False"
                                               IsZoomButtonVisible="False"
                                               IsZoomEnabled="False"
                                               Style="{StaticResource customTransportControlsStyle}"
                                               >
                </local:MixedMediaPlayerControl>
            </MediaPlayerElement.TransportControls>
        </MediaPlayerElement>
    </Grid>
</Page>
